# Project configuration for external mode
# Copy this file to projects/<name>/project.conf and fill in values.

# Git repository URL (required for external mode)
# REPO_URL=https://github.com/org/repo.git

# Branch to work on (default: main)
# BRANCH=main

# Local path to the repo on the host (optional)
# If set, the harness mounts this path instead of cloning.
# Useful for repos already checked out locally.
# LOCAL_PATH=/home/user/projects/my-repo

{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "WebSearch",
      "Bash(CLAUDECODE= claude:*)",
      "Bash(claude:*)",
      "Bash(env:*)",
      "Bash(cat:*)",
      "Bash(lb:*)",
      "Bash(bun:*)",
      "Bash(node:*)",
      "Bash(gh repo:*)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "lb prime"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "lb prime"
          }
        ]
      }
    ]
  }
}
